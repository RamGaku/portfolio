PORT=8787

# Inline content editor admin credentials (defaults: admin42 / 0909)
ADMIN_ID=admin42
ADMIN_PW=0909

# Vertex AI is used when enabled and a Google Cloud project is configured.
VERTEX_AI_ENABLED=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
VERTEX_AI_MODEL=gemini-2.5-flash

# Vector RAG embeddings (semantic search over the KB).
# Falls back to keyword search if unavailable.
VERTEX_EMBED_MODEL=text-multilingual-embedding-002
VERTEX_EMBED_LOCATION=asia-northeast3

# Local development auth option:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
